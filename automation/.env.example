# Copy to automation/.env for local runs; on Railway set these as service variables.
# The pipeline holds two secrets: a GitHub token (commit datasets) and an Airtable
# token (write firm rows). Both scoped to one repo / one base.

# --- GitHub (commit refreshed / new datasets) ---
GITHUB_TOKEN=github_pat_xxx        # fine-grained PAT, Contents: read+write on the ONE repo
GITHUB_REPO=ruszinn/vc-comp        # owner/name
GITHUB_BRANCH=main
GITHUB_DATA_DIR=data

# --- Airtable (direct write into Private Comps) ---
AIRTABLE_PAT=pat_xxx               # data.records:read + data.records:write on the base
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
AIRTABLE_TABLE=Private Comps

# --- tuning ---
SCRAPER_TIMEOUT=600                # per-bespoke-scraper subprocess budget (seconds)
GENERIC_CONFIDENCE=0.6             # new-firm extraction below this -> needs-scraper
